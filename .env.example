# Required
DATABASE_URL=postgres://signup:signup@localhost:5433/signup
AUTH_SECRET=change-me-to-a-32-byte-random-string-XXXXXXXXX
AUTH_URL=http://localhost:3000

# Email transport: console | smtp | resend
EMAIL_TRANSPORT=console
EMAIL_FROM="OpenSignup <hello@signup.local>"

# If EMAIL_TRANSPORT=resend
RESEND_API_KEY=

# If EMAIL_TRANSPORT=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# Optional observability (unset = disabled)
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com

# Optional OAuth (v2+)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public base URL (used for building participant/share links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
